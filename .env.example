# ─── 必填 ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@AgenticNow

# ─── 可选 ────────────────────────────────────────
# 每次推送最多文章数（默认12）
MAX_ARTICLES_PER_RUN=12

# 抓取多久内的文章，单位小时（默认48）
HOURS_LOOKBACK=48

# 推送模式: individual=每篇单独发; digest=每日合集
PUBLISH_MODE=individual

# 是否启用 X/Twitter 信源（需要 RSSHub 实例）
ENABLE_TWITTER=false

# RSSHub 实例地址（用于 X/Twitter 信源抓取）
RSSHUB_BASE_URL=https://rsshub.app
